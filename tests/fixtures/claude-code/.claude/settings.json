      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "lint-check.sh" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "notify-complete.sh" }]
      }
    ]
  },
